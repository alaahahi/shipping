APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Production MySQL (default when APP_ENV != local):
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=shipping
DB_USERNAME=root
DB_PASSWORD=

# Production SQLite cutover (see docs/SQLITE_CUTOVER_ROLLBACK.md):
# DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/database/shipping.sqlite
# DB_FOREIGN_KEYS=true
# LOCAL_NO_REMOTE=false

# Local sync file (used when APP_ENV=local or LOCAL_NO_REMOTE=true):
# SYNC_SQLITE_PATH=database/sync.sqlite
# DB_FALLBACK_CONNECTION=sync_sqlite

API_KEY=
ONLINE_URL=
LOCAL_URL=http://127.0.0.1:8000
SECOND_PROJECT_URL=

LOCAL_NO_REMOTE=false
SYNC_AUTO_ENABLED=true
SYNC_REQUIRE_API_KEY=false

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
